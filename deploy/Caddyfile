{$ORIONETA_DOMAIN:orioneta.accesscam.org} {
	encode zstd gzip

	@backend {
		path /api/* /actuator/* /swagger-ui/* /v3/api-docs* /oauth2/* /login/oauth2/* /ws*
	}

	handle @backend {
		reverse_proxy {$BACKEND_UPSTREAM:http://host.docker.internal:8080}
	}

	handle {
		reverse_proxy orioneta-public-frontend:80
	}
}
